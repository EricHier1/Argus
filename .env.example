# Copy to .env and edit. The real .env is gitignored (it may contain camera
# passwords). Argus loads .env on startup; restart after editing. Every value
# below shows its built-in default — uncomment a line only to override it.
# Full reference: app/config.py

# === Cameras ===============================================================
# Cameras opened on startup (comma-separated; a camera index or an rtsp:// URL).
# RTSP with a login: rtsp://USER:PASS@IP:PORT/path   (percent-encode special
# chars in the password, e.g. ! -> %21). Use the menu's "Detect stream URL"
# (ONVIF) to find a camera's path automatically.
ARGUS_SOURCES=0
# ARGUS_SOURCE=0                # singular fallback; ignored when ARGUS_SOURCES is set

# === Detection / model =====================================================
# ARGUS_MODEL=yolo11n.pt        # 'n'=nano (lightest). yolo11s/m/l/x = more accurate + heavier (auto-downloads)
# ARGUS_CONFIDENCE=0.45         # min confidence to record a detection; raise to 0.5-0.6 for fewer false logs
# ARGUS_DETECT_INTERVAL=0.0     # seconds between inferences; 0=every frame. 0.3-0.5 = less CPU/GPU + heat
# ARGUS_DEVICE=auto             # auto -> Apple GPU (mps) on a Mac. Force: mps | cpu | cuda
# ARGUS_TRACK=1                 # 1=ByteTrack (log once per appearance). 0=log every detection cycle

# === Snapshot / logging cadence (controls how fast data/snapshots/ fills) ==
# ARGUS_SNAPSHOT_INTERVAL=2.0   # min seconds between saved snapshots; raise to slow disk growth
# ARGUS_PERSIST_INTERVAL=2.0    # lingering object: snapshot this often for its first minute
# ARGUS_DWELL_TIER_1=60         # after this many seconds in frame -> snapshot 1/min
# ARGUS_DWELL_TIER_2=600        # after this -> 1/hour
# ARGUS_DWELL_TIER_3=3600       # after this -> stop logging it until it leaves
# ARGUS_LEAVE_GAP=60            # unseen this long = "left"; re-entry restarts its cadence

# === Server / exposure =====================================================
# Exposure: lan (wifi) | local (this machine) | tailscale (trusted remote)
# ARGUS_BIND=lan
# ARGUS_PORT=8000               # web UI port
# ARGUS_HTTPS=1                 # 1=self-signed TLS; 0=plain http
# ARGUS_HOST=                   # advanced: force bind address (normally derived from ARGUS_BIND)

# === Alerts ================================================================
# ARGUS_ALERT_COOLDOWN=30       # seconds before the same alert rule can fire again

# === RTSP / FFmpeg (raw OpenCV vars, not ARGUS_-prefixed; loaded from here too) ==
# OPENCV_FFMPEG_CAPTURE_OPTIONS=rtsp_transport;tcp|stimeout;5000000   # swap tcp->udp if a cam stutters
# OPENCV_FFMPEG_LOGLEVEL=8      # 8=hide ffmpeg decode spam; raise (16/24) to debug a flaky stream

# Note: snapshot retention (retention_days / max_snapshots) is NOT set here —
# it's a dashboard setting (Settings panel), stored in the DB. Default = no cleanup.
